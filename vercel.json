{
  "buildCommand": "npm run build",
  "outputDirectory": ".output/public",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://api-retailfixit-dev.redplant-5c8db0a0.eastus.azurecontainerapps.io/v1/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
